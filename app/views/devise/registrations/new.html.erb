<div class="auth-page">
  <div class="auth-container">
    <h2>Sign Up</h2>
    <p class="auth-subtitle">Start your journey with AI News</p>

    <%= simple_form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f| %>
      

      <div class="auth-form-group">
        <%= f.label :email, "Email Address" %>
        <%= f.input_field :email,
                          required: true,
                          autofocus: true,
                          placeholder: "your@email.com",
                          input_html: { autocomplete: "email" } %>
      </div>

      <div class="auth-form-group">
        <%= f.label :password, "Password" %>
        <%= f.input_field :password,
                          required: true,
                          placeholder: "Enter password",
                          input_html: { autocomplete: "new-password" } %>
        <% if @minimum_password_length %>
          <span class="auth-hint"><%= @minimum_password_length %> characters minimum</span>
        <% end %>
      </div>

      <div class="auth-form-group">
        <%= f.label :password_confirmation, "Confirm Password" %>
        <%= f.input_field :password_confirmation,
                          required: true,
                          placeholder: "Confirm password",
                          input_html: { autocomplete: "new-password" } %>
      </div>

      <div class="auth-actions">
        <%= f.button :submit, "Sign Up", class: "auth-btn" %>
      </div>
    <% end %>

    <div class="auth-links">
      <%= render "devise/shared/links" %>
    </div>
  </div>
</div>
